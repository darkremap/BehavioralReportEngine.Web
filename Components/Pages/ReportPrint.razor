@page "/reports/{Id:long}/print"
@layout Layout.PrintLayout
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@using BehavioralReportEngine.Web.ViewModels
@using System.Globalization

@if (_model == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    var report = _model.Report;
    var gameName = report.GameVersion?.Game?.NameEn ?? report.GameVersion?.Game?.NameFa ?? "";
    var participantName = report.Participant != null
        ? (string.IsNullOrWhiteSpace(report.Participant.FullNameFa) ? report.Participant.FullNameEn : report.Participant.FullNameFa)
        : (report.Team?.TeamName ?? "-");
    var reportDate = ReportPrintViewModel.ToPersianDate(report.GeneratedAt ?? report.CreatedAt);
    var reportCode = $"ANA-{report.ReportId}";
    int pageNumber = 1;

    <style>
        .report-page { box-shadow: 0 4px 24px rgba(20,40,35,0.08); }
        .cover-page { display: flex; flex-direction: column; align-items: center; text-align: center; overflow: hidden; }
        .cover-logo { max-height: 90px; margin-top: 30px; }
        .cover-title { font-size: 46px; font-weight: 800; letter-spacing: 6px; color: #1b4332; margin: 24px 0 4px; }
        .cover-subtitle { font-size: 20px; font-weight: 600; color: #223; margin-bottom: 2px; }
        .cover-subtitle-en { font-size: 12px; letter-spacing: 3px; color: #999; text-transform: uppercase; margin-bottom: 40px; }
        .cover-info { width: 100%; max-width: 480px; text-align: right; margin-top: 20px; position: relative; z-index: 2; }
        .cover-info-row { display: flex; align-items: center; gap: 10px; padding: 14px 4px; }
        .cover-info-row .row-icon { width: 22px; height: 22px; color: #1b4332; flex-shrink: 0; }
        .cover-info-row .row-icon svg { width: 100%; height: 100%; }
        .cover-info-row .label { color: #1b4332; font-weight: 600; font-size: 15px; white-space: nowrap; }
        .cover-info-row .row-sep { width: 1px; height: 16px; background: #d8dde0; flex-shrink: 0; }
        .cover-info-row .value { flex: 1; font-weight: 700; color: #14213d; font-size: 15px; border-bottom: 1px dotted #ccc; padding-bottom: 8px; }
        .cover-footer-note { margin-top: auto; font-size: 12px; color: #888; border-top: 1px solid #eee; padding-top: 14px; position: relative; z-index: 2; max-width: 480px; }
        .cover-waves { position: absolute; left: 0; right: 0; bottom: 0; width: 100%; height: auto; z-index: 1; opacity: 0.9; }
        .page-header { display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #1b4332; font-weight: 700; border-bottom: 2px solid #eef4f2; padding-bottom: 10px; margin-bottom: 20px; }
        .page-header .page-num { background: #1b4332; color: #fff; border-radius: 6px; padding: 2px 10px; font-size: 12px; }
        h1.page-title { font-size: 26px; color: #14213d; margin: 0 0 6px; }
        p.page-desc { color: #667; font-size: 13px; max-width: 640px; margin-bottom: 20px; }
        .card-box { background: #f7fafa; border: 1px solid #e7efee; border-radius: 10px; padding: 16px 18px; margin-bottom: 16px; }
        .card-box h3 { font-size: 15px; margin: 0 0 10px; color: #1b4332; display: flex; align-items: center; gap: 6px; }
        .radar-page-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
        .info-callout { display: flex; gap: 8px; align-items: flex-start; background: #f7fafa; border: 1px solid #e7efee; border-radius: 10px; padding: 10px 14px; font-size: 11px; color: #556; max-width: 220px; flex-shrink: 0; }
        .radar-wrap { display: flex; justify-content: center; margin: 10px 0 20px; }
        .radar-wrap canvas { max-width: 480px; max-height: 480px; }
        .legend-row { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; font-size: 11px; color: #555; }
        .legend-dot { display: inline-block; width: 9px; height: 9px; border-radius: 50%; margin-left: 4px; }
        .indicator-layout { display: flex; gap: 22px; }
        .indicator-aside { width: 190px; flex-shrink: 0; text-align: center; }
        .indicator-icon-circle { width: 64px; height: 64px; border-radius: 50%; background: #eaf6f4; border: 1px solid #d9f0ec; display: flex; align-items: center; justify-content: center; font-size: 28px; margin: 0 auto 12px; }
        .score-caption { font-size: 12px; color: #889; margin-bottom: 2px; }
        .score { font-size: 34px; font-weight: 800; color: #2a9d8f; direction: ltr; unicode-bidi: embed; }
        .score small { font-size: 16px; color: #999; }
        .score-bar-track { width: 100%; height: 6px; background: #e7efee; border-radius: 3px; overflow: hidden; margin: 10px 0 6px; }
        .score-bar-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, #2a9d8f, #1b4332); }
        .level-plain { font-weight: 700; font-size: 14px; margin-top: 4px; }
        .dots { display: flex; justify-content: center; gap: 4px; margin: 8px 0; }
        .dot { width: 9px; height: 9px; border-radius: 50%; background: #ddd; }
        .dot.filled { background: #2a9d8f; }
        .indicator-quote-box { background: #f7fafa; border: 1px solid #e7efee; border-radius: 10px; padding: 16px 14px; margin-top: 20px; text-align: center; position: relative; }
        .indicator-quote-box .quote-mark { font-size: 26px; color: #2a9d8f; line-height: 1; font-weight: 800; }
        .indicator-quote-box p { font-size: 12px; color: #556; font-style: italic; line-height: 1.8; margin: 4px 0 0; }
        .indicator-main { flex: 1; }
        ul.evidence-list { list-style: none; padding: 0; margin: 0; }
        ul.evidence-list li { padding: 6px 0; border-bottom: 1px dashed #eee; font-size: 13px; }
        ul.evidence-list li:before { content: "✓ "; color: #2a9d8f; font-weight: 700; }
        .behavior-chips-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .behavior-chip { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 6px; background: #fff; border: 1px solid #eef3f2; border-radius: 10px; padding: 12px 8px; }
        .behavior-chip-icon { width: 34px; height: 34px; border-radius: 50%; background: #f7fafa; display: flex; align-items: center; justify-content: center; font-size: 16px; }
        .behavior-chip span { font-size: 12px; font-weight: 600; color: #334; }
        ul.growth-list { list-style: none; padding: 0; margin: 0; }
        ul.growth-list li { display: flex; align-items: flex-start; gap: 8px; padding: 6px 0; font-size: 13px; }
        ul.growth-list li:before { content: "●"; color: #2a9d8f; font-size: 8px; margin-top: 6px; flex-shrink: 0; }
        .pattern-row { display: flex; align-items: center; gap: 14px; padding: 12px 0; border-bottom: 1px solid #eee; }
        .pattern-row .name { width: 190px; font-weight: 700; display: flex; align-items: center; gap: 6px; }
        .pattern-row .bar-track { flex: 1; background: #eee; border-radius: 6px; height: 10px; overflow: hidden; }
        .pattern-row .bar-fill { background: linear-gradient(90deg, #2a9d8f, #1b4332); height: 100%; border-radius: 6px; }
        .pattern-row .score { width: 60px; text-align: left; font-weight: 700; color: #2a9d8f; font-size: 13px; }
        .pattern-row.dominant .name { color: #1b4332; }
        .dominant-badge { display: inline-block; background: #fff3cd; color: #b8860b; font-size: 10px; padding: 2px 8px; border-radius: 10px; }

        /* === سکشن الگوهای رفتاری مشاهده‌شده === */
        .pattern-aside { width: 190px; flex-shrink: 0; text-align: center; position: relative; overflow: hidden; padding-bottom: 20px; }
        .pattern-aside h2 { font-size: 18px; margin: 0 0 14px; line-height: 1.4; }
        .pattern-aside-waves { position: absolute; left: 0; right: 0; bottom: 0; width: 100%; z-index: 0; opacity: 0.8; }
        .pattern-aside-content { position: relative; z-index: 1; }
        .pattern-aside-desc { font-size: 12px; color: #667; margin-top: 14px; line-height: 1.9; }
        .pattern-card { display: flex; gap: 14px; align-items: flex-start; background: #f9fcfb; border: 1px solid #eef3f2; border-radius: 12px; padding: 16px; margin-bottom: 14px; }
        .pattern-card.dominant { border-color: #cfe9e4; background: #f2faf8; }
        .pattern-card-icon { width: 46px; height: 46px; border-radius: 50%; background: #eaf6f4; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
        .pattern-card-body { flex: 1; }
        .pattern-card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
        .pattern-card-name { font-size: 16px; font-weight: 800; color: #1b2a33; }
        .pattern-card-score-wrap { text-align: left; flex-shrink: 0; }
        .pattern-card-score-caption { font-size: 10px; color: #99a; }
        .pattern-card-score { font-size: 22px; font-weight: 800; color: #2a9d8f; direction: ltr; unicode-bidi: embed; }
        .pattern-card-score small { font-size: 12px; color: #999; font-weight: 600; }
        .pattern-card-desc { font-size: 12px; color: #667; margin: 6px 0 12px; }
        .pattern-line-track { position: relative; height: 4px; background: #e7efee; border-radius: 2px; }
        .pattern-line-fill { position: relative; height: 100%; background: #2a9d8f; border-radius: 2px; }
        .pattern-line-fill:after { content: ""; position: absolute; left: 0; top: 50%; width: 12px; height: 12px; border-radius: 50%; background: #2a9d8f; border: 2px solid #fff; box-shadow: 0 0 0 1px #2a9d8f; transform: translate(-50%, -50%); }
        .summary-icon-box { width: 48px; height: 48px; border-radius: 14px; background: #1b4332; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
        .moment-item { display: flex; gap: 14px; padding: 12px 0; border-bottom: 1px dashed #eee; }
        .moment-time { width: 60px; flex-shrink: 0; font-weight: 700; color: #fff; background: #2a9d8f; border-radius: 6px; text-align: center; padding: 3px 0; font-size: 12px; height: fit-content; }
        .moment-title { font-weight: 700; margin-bottom: 2px; }
        .moment-desc { font-size: 13px; color: #556; }

        /* === سکشن لحظات کلیدی جلسه === */
        .moment-aside-ring { width: 64px; height: 64px; border-radius: 50%; background: conic-gradient(#2a9d8f 0deg 260deg, #e7efee 260deg 360deg); display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; }
        .moment-aside-ring-inner { width: 52px; height: 52px; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 24px; }
        .aside-divider { width: 30px; height: 1px; background: #dcdfe1; margin: 16px auto; }
        .moment-card { position: relative; display: flex; align-items: flex-start; gap: 14px; background: #f9fcfb; border: 1px solid #eef3f2; border-radius: 12px; padding: 14px 16px; margin-bottom: 16px; }
        .moment-card-icon { width: 48px; height: 48px; border-radius: 50%; background: #eaf6f4; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
        .moment-card-body { flex: 1; }
        .moment-card-top { display: flex; align-items: baseline; gap: 10px; margin-bottom: 4px; flex-wrap: wrap; }
        .moment-card-time { color: #2a9d8f; font-weight: 700; font-size: 13px; direction: ltr; unicode-bidi: embed; }
        .moment-card-title { font-weight: 800; font-size: 15px; color: #1b2a33; }
        .moment-card-desc { font-size: 12px; color: #667; line-height: 1.8; }
        .moment-card-num-wrap { width: 30px; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; position: relative; }
        .moment-card-num { width: 26px; height: 26px; border-radius: 50%; background: #1b4332; color: #fff; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; z-index: 1; }
        .moment-card-num-wrap:after { content: ""; position: absolute; top: 26px; bottom: -16px; left: 50%; width: 2px; background: #e3ece9; transform: translateX(-50%); }
        .moment-card:last-child .moment-card-num-wrap:after { display: none; }
        .growth-cols { display: flex; gap: 14px; }
        .growth-col { flex: 1; background: #f7fafa; border-radius: 10px; padding: 14px; border-top: 3px solid #ddd; }
        .growth-col-header { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
        .growth-col-icon { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #fff; flex-shrink: 0; }
        .growth-col h4 { font-size: 14px; margin: 0; }
        .growth-col-caption { font-size: 11px; color: #99a; margin: 2px 0 10px; }
        .growth-col-divider { width: 100%; height: 1px; background: #e3ece9; margin-bottom: 10px; }
        .growth-col-footer { display: flex; align-items: flex-start; gap: 6px; margin-top: 12px; padding: 10px; border-radius: 8px; font-size: 10.5px; line-height: 1.6; }
        .growth-col-footer.tone-green { background: #eaf6f4; color: #1b4332; }
        .growth-col-footer.tone-blue { background: #eaf3fb; color: #2c5d82; }
        .growth-col-footer.tone-orange { background: #fdf0e9; color: #a15326; }
        .growth-entry { font-size: 12px; margin-bottom: 8px; padding-bottom: 8px; border-bottom: 1px dashed #ddd; }
        .growth-entry .area { font-weight: 700; }
        .priority-badge { display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 10px; margin-left: 6px; }
        .priority-High { background: #fde2e2; color: #c0392b; }
        .priority-Medium { background: #fff3cd; color: #b8860b; }
        .priority-Low { background: #e6f4ea; color: #2a9d8f; }
        .page-footer { position: absolute; bottom: 10mm; left: 12mm; right: 12mm; display: flex; justify-content: space-between; align-items: center; font-size: 10px; color: #aab; border-top: 1px solid #f0f0f0; padding-top: 8px; }
        .page-footer .brand { letter-spacing: 2px; font-weight: 700; color: #9aa; text-transform: uppercase; }

        /* === سکشن نقشه پنج شاخص کلیدی (رادار با آیکن‌های پیرامونی) === */
        .section-accent { width: 40px; height: 4px; background: #2a9d8f; border-radius: 2px; margin-bottom: 14px; }
        .radar-chart-container { position: relative; width: 600px; height: 600px; margin: 20px auto 30px; }
        .radar-chart-container canvas { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 420px !important; height: 420px !important; }
        .radar-vertex { position: absolute; transform: translate(-50%, -50%); text-align: center; width: 110px; }
        .radar-vertex-icon { width: 40px; height: 40px; border-radius: 50%; background: #f7fafa; border: 1px solid #e7efee; display: flex; align-items: center; justify-content: center; font-size: 18px; margin: 0 auto 6px; }
        .radar-vertex-name { font-size: 13px; font-weight: 700; color: #1b2a33; }
        .radar-vertex-score { font-size: 20px; font-weight: 800; color: #2a9d8f; }
        .radar-vertex-score small { font-size: 12px; color: #999; font-weight: 600; }
        .legend-card { display: flex; border: 1px solid #e7efee; border-radius: 10px; overflow: hidden; margin-bottom: 20px; }
        .legend-col { flex: 1; text-align: center; padding: 14px 6px; border-left: 1px solid #eef4f2; }
        .legend-col:last-child { border-left: none; }
        .legend-range { font-weight: 700; font-size: 13px; color: #223; margin-bottom: 8px; }
        .legend-dots { display: flex; justify-content: center; gap: 4px; margin-bottom: 8px; }
        .legend-dot-lg { width: 10px; height: 10px; border-radius: 50%; background: #e7efee; }
        .legend-label { font-size: 12px; font-weight: 700; }
    </style>

    <div class="report-page cover-page">
        <svg class="cover-waves" viewBox="0 0 800 220" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,120 C150,180 300,60 450,110 C600,160 700,90 800,130 L800,220 L0,220 Z" fill="#eaf6f4" />
            <path d="M0,150 C180,90 320,190 500,140 C650,100 720,170 800,150 L800,220 L0,220 Z" fill="#d7efec" />
            <path d="M0,180 C200,140 350,210 550,170 C680,145 730,200 800,180 L800,220 L0,220 Z" fill="#2a9d8f" opacity="0.35" />
        </svg>
        @if (!string.IsNullOrEmpty(report.Organization?.LogoPath))
        {
            <img src="@report.Organization.LogoPath" class="cover-logo" alt="Logo" />
        }
        <div class="cover-title">@gameName</div>
        <div class="cover-subtitle">گزارش مشاهده رفتاری</div>
        <div class="cover-subtitle-en">BEHAVIORAL OBSERVATION REPORT</div>
        <div class="cover-info">
            <div class="cover-info-row">
                <span class="row-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
                </span>
                <span class="label">نام فرد</span>
                <span class="row-sep"></span>
                <span class="value">@participantName</span>
            </div>
            <div class="cover-info-row">
                <span class="row-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="1"/><path d="M9 8h1M14 8h1M9 12h1M14 12h1M9 16h1M14 16h1"/></svg>
                </span>
                <span class="label">سازمان</span>
                <span class="row-sep"></span>
                <span class="value">@(report.Organization?.Name ?? "-")</span>
            </div>
            <div class="cover-info-row">
                <span class="row-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/></svg>
                </span>
                <span class="label">تاریخ اجرا</span>
                <span class="row-sep"></span>
                <span class="value">@reportDate</span>
            </div>
            <div class="cover-info-row">
                <span class="row-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h9l5 5v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/><path d="M14 3v5h5M8 13h8M8 17h8"/></svg>
                </span>
                <span class="label">کد گزارش</span>
                <span class="row-sep"></span>
                <span class="value">@reportCode</span>
            </div>
        </div>
        <div class="cover-footer-note">
            این گزارش بر اساس مشاهده رفتار در یک تجربه گروهی تهیه شده و به منزله تشخیص شخصیت یا ارزیابی روان‌شناختی نیست.
        </div>
    </div>

    @if (_model.IndicatorScores.Any())
    {
        pageNumber++;
        var overviewCount = _model.IndicatorScores.Count;
        var overviewSummary = _model.DominantPatterns.FirstOrDefault(p => !string.IsNullOrWhiteSpace(p.Description))?.Description;
        <div class="report-page">
            <div class="page-header">
                <span>@gameName | گزارش مشاهده رفتاری</span>
                <span class="page-num">@pageNumber.ToString("00")</span>
            </div>
            <div class="section-accent"></div>
            <div class="radar-page-top">
                <div>
                    <h1 class="page-title">نقشه پنج شاخص کلیدی @participantName</h1>
                    <p class="page-desc">این نمودار خلاصه‌ای از الگوی تعاملی @participantName در این تجربه گروهی است. هر شاخص نشان‌دهنده یک بعد کلیدی از رفتار @participantName است.</p>
                </div>
                <div class="info-callout">
                    <span>ℹ️</span>
                    <span>این نتایج بر اساس مشاهده رفتار @participantName در یک تجربه گروهی واقعی تهیه شده است.</span>
                </div>
            </div>

            <div class="radar-chart-container">
                <canvas id="radarChart" width="420" height="420"></canvas>
                @foreach (var (s, vi) in _model.IndicatorScores.Select((s, idx) => (s, idx)))
                {
                    var angle = -Math.PI / 2 + vi * (2 * Math.PI / overviewCount);
                    var vx = (50 + 46 * Math.Cos(angle)).ToString("0.##", CultureInfo.InvariantCulture);
                    var vy = (50 + 46 * Math.Sin(angle)).ToString("0.##", CultureInfo.InvariantCulture);
                    var vIcon = ReportPrintViewModel.GetIndicatorIcon(s.IndicatorDefinition?.IndicatorCode, s.IndicatorDefinition?.Title);
                    var vMax = s.ScoringScale?.MaxValue ?? 5m;
                    <div class="radar-vertex" style="left:@(vx)%; top:@(vy)%;">
                        <div class="radar-vertex-icon">@vIcon</div>
                        <div class="radar-vertex-name">@s.IndicatorDefinition?.Title</div>
                        <div class="radar-vertex-score">@s.ScoreValue.ToString("0.0")<small>/@vMax.ToString("0.#")</small></div>
                    </div>
                }
            </div>

            <div class="legend-card">
                @{
                    var buckets = new (string Range, string Label, string Color)[]
                    {
                        ("1 - 1.9", "نیاز به توجه", "#e63946"),
                        ("2 - 2.9", "نیاز به رشد", "#f4a261"),
                        ("3 - 3.9", "متوسط", "#e9c46a"),
                        ("4 - 4.5", "خوب", "#2a9d8f"),
                        ("4.6 - 5", "بسیار قوی", "#1b4332"),
                    };
                }
                @for (int b = 0; b < buckets.Length; b++)
                {
                    var bucket = buckets[b];
                    <div class="legend-col">
                        <div class="legend-range">@bucket.Range</div>
                        <div class="legend-dots">
                            @for (int d = 0; d < 4; d++)
                            {
                                <span class="legend-dot-lg" style="@(d <= b ? $"background:{bucket.Color};" : "")"></span>
                            }
                        </div>
                        <div class="legend-label" style="color:@bucket.Color;">@bucket.Label</div>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(overviewSummary))
            {
                <div class="card-box"><h3>📋 خلاصه</h3><p style="font-size:13px;">@overviewSummary</p></div>
            }

            <div class="page-footer">
                <span class="brand">ANA — Behavior Intelligence</span>
                <span>@reportCode</span>
            </div>
        </div>
    }

    @foreach (var score in _model.IndicatorScores)
    {
        pageNumber++;
        var max = score.ScoringScale?.MaxValue ?? 5m;
        var level = ReportPrintViewModel.GetLevel(score.ScoreValue, max);
        var (levelLabel, levelColor) = ReportPrintViewModel.GetLevelInfo(level);
        var filledDots = (int)Math.Round((score.ScoreValue / max) * 5m);
        var icon = ReportPrintViewModel.GetIndicatorIcon(score.IndicatorDefinition?.IndicatorCode, score.IndicatorDefinition?.Title);
        var quote = ReportPrintViewModel.GetIndicatorQuote(score.IndicatorDefinition?.Title);
        var scorePct = max > 0 ? (double)(score.ScoreValue / max) * 100 : 0;
        var behaviorIcons = new[] { "\U0001F441", "\U0001F9E0", "\U0001F4AC", "\U0001F9E9" };
        <div class="report-page">
            <div class="page-header"><span>@gameName | گزارش مشاهده رفتاری</span><span class="page-num">@pageNumber.ToString("00")</span></div>
            <div class="indicator-layout">
                <div class="indicator-aside">
                    <div class="indicator-icon-circle">@icon</div>
                    <h2 style="font-size:18px;margin-bottom:4px;">@score.IndicatorDefinition?.Title</h2>
                    <div style="font-size:11px;color:#999;text-transform:uppercase;margin-bottom:10px;">@score.IndicatorDefinition?.TitleEn</div>
                    <div class="score-caption">امتیاز شما</div>
                    <div class="score">@score.ScoreValue.ToString("0.0") <small>/@max.ToString("0.#")</small></div>
                    <div class="score-bar-track"><div class="score-bar-fill" style="width:@(scorePct)%;"></div></div>
                    <div class="dots">
                        @for (int i = 0; i < 5; i++)
                        {
                            <span class="@(i < filledDots ? "dot filled" : "dot")"></span>
                        }
                    </div>
                    <div class="level-plain" style="color:@levelColor;">@levelLabel</div>
                    @if (!string.IsNullOrWhiteSpace(score.IndicatorDefinition?.ShortDefinition))
                    {
                        <p style="font-size:12px;color:#667;margin-top:14px;">@score.IndicatorDefinition.ShortDefinition</p>
                    }
                    <div class="indicator-quote-box">
                        <div class="quote-mark">❝</div>
                        <p>@quote</p>
                    </div>
                </div>
                <div class="indicator-main">
                    @if (!string.IsNullOrWhiteSpace(score.ObservedEvidence))
                    {
                        <div class="card-box">
                            <h3>🔎 شواهد مشاهده شده</h3>
                            <ul class="evidence-list">
                                @foreach (var line in score.ObservedEvidence.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <li>@line.Trim()</li>
                                }
                            </ul>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(score.IndicatorBehaviors))
                    {
                        <div class="card-box">
                            <h3>🏅 رفتارهای شاخص</h3>
                            <div class="behavior-chips-grid">
                                @foreach (var (line, bi) in score.IndicatorBehaviors.Split('\n', StringSplitOptions.RemoveEmptyEntries).Select((l, idx) => (l, idx)))
                                {
                                    <div class="behavior-chip">
                                        <div class="behavior-chip-icon">@behaviorIcons[bi % behaviorIcons.Length]</div>
                                        <span>@line.Trim()</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(score.Strengths))
                    {
                        <div class="card-box"><h3>⭐ نقاط قوت</h3><p style="font-size:13px;">@score.Strengths</p></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(score.GrowthOpportunities))
                    {
                        <div class="card-box">
                            <h3>🌱 فرصت‌های رشد</h3>
                            <ul class="growth-list">
                                @foreach (var line in score.GrowthOpportunities.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <li>@line.Trim()</li>
                                }
                            </ul>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(score.PracticalRecommendation))
                    {
                        <div class="card-box"><h3>💡 توصیه کاربردی</h3><p style="font-size:13px;">@score.PracticalRecommendation</p></div>
                    }
                </div>
            </div>
            <div class="page-footer"><span class="brand">ANA — Behavior Intelligence</span><span>@reportCode</span></div>
        </div>
    }

    @if (_model.PatternScores.Any())
    {
        pageNumber++;
        var patternMax = _model.PatternScores.Count;
        var patternMaxDec = (decimal)patternMax;
        var avgPatternScore = _model.PatternScores.Where(p => p.ScoreValue.HasValue).Select(p => p.ScoreValue!.Value).DefaultIfEmpty(0).Average();
        var patternLevel = ReportPrintViewModel.GetLevel(avgPatternScore, patternMaxDec);
        var (patternLevelLabel, patternLevelColor) = ReportPrintViewModel.GetLevelInfo(patternLevel);
        var patternFilledDots = patternMaxDec > 0 ? (int)Math.Round((avgPatternScore / patternMaxDec) * 5m) : 0;
        var patternScorePct = patternMaxDec > 0 ? (double)(avgPatternScore / patternMaxDec) * 100 : 0;
        <div class="report-page">
            <div class="page-header"><span>@gameName | گزارش مشاهده رفتاری</span><span class="page-num">@pageNumber.ToString("00")</span></div>
            <h1 class="page-title">الگوهای رفتاری مشاهده‌شده</h1>
            <p class="page-desc">بر اساس تحلیل گفتگوی @participantName، الگوی رفتاری اصلی در تعاملات شناسایی شده است.</p>

            <div class="indicator-layout">
                <div class="pattern-aside">
                    <div class="pattern-aside-content">
                        <div class="indicator-icon-circle">👥</div>
                        <h2>الگوهای رفتاری مشاهده‌شده</h2>
                        <div class="score-caption">امتیاز شما</div>
                        <div class="score">@avgPatternScore.ToString("0.0") <small>/@patternMax</small></div>
                        <div class="score-bar-track"><div class="score-bar-fill" style="width:@(patternScorePct)%;"></div></div>
                        <div class="dots">
                            @for (int i = 0; i < 5; i++)
                            {
                                <span class="@(i < patternFilledDots ? "dot filled" : "dot")"></span>
                            }
                        </div>
                        <div class="score-caption" style="margin-top:10px;">سطح بروز الگوها</div>
                        <div class="level-plain" style="color:@patternLevelColor;">@patternLevelLabel</div>
                        <p class="pattern-aside-desc">این بخش نشان می‌دهد در طول گفتگو بیشتر از کدام الگوهای رفتاری استفاده کرده‌اید. شناخت این الگوها به شما کمک می‌کند نقاط قوت خود را تقویت و رفتارهای مؤثرتری را در تعاملات آینده انتخاب کنید.</p>
                    </div>
                    <svg class="pattern-aside-waves" viewBox="0 0 800 220" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0,120 C150,180 300,60 450,110 C600,160 700,90 800,130 L800,220 L0,220 Z" fill="#eaf6f4" />
                        <path d="M0,150 C180,90 320,190 500,140 C650,100 720,170 800,150 L800,220 L0,220 Z" fill="#d7efec" />
                        <path d="M0,180 C200,140 350,210 550,170 C680,145 730,200 800,180 L800,220 L0,220 Z" fill="#2a9d8f" opacity="0.35" />
                    </svg>
                </div>

                <div class="indicator-main">
                    @foreach (var p in _model.PatternScores)
                    {
                        var pct = patternMax > 0 && p.ScoreValue.HasValue ? (double)(p.ScoreValue.Value / patternMax) * 100 : 0;
                        var pIcon = ReportPrintViewModel.GetPatternIcon(p.BehavioralPattern?.PatternCode, p.BehavioralPattern?.Name);
                        <div class="pattern-card @(p.IsDominantPattern ? "dominant" : "")">
                            <div class="pattern-card-icon">@pIcon</div>
                            <div class="pattern-card-body">
                                <div class="pattern-card-header">
                                    <div class="pattern-card-name">
                                        @p.BehavioralPattern?.Name
                                        @if (p.IsDominantPattern)
                                        {
                                            <span class="dominant-badge">غالب ⭐</span>
                                        }
                                    </div>
                                    <div class="pattern-card-score-wrap">
                                        <div class="pattern-card-score-caption">امتیاز از @patternMax</div>
                                        <div class="pattern-card-score">@(p.ScoreValue?.ToString("0.0") ?? "-") <small>/@patternMax</small></div>
                                    </div>
                                </div>
                                @{ var patternCardDesc = !string.IsNullOrWhiteSpace(p.Description) ? p.Description : p.BehavioralPattern?.Description; }
                                @if (!string.IsNullOrWhiteSpace(patternCardDesc))
                                {
                                    <div class="pattern-card-desc">@patternCardDesc</div>
                                }
                                <div class="pattern-line-track"><div class="pattern-line-fill" style="width:@(pct)%;"></div></div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @{ var summaryText = _model.PatternScores.FirstOrDefault(p => !string.IsNullOrWhiteSpace(p.Description))?.Description; }
            @if (!string.IsNullOrWhiteSpace(summaryText))
            {
                <div class="card-box" style="margin-top:20px; display:flex; align-items:flex-start; gap:16px;">
                    <div class="summary-icon-box">📋</div>
                    <div>
                        <h3 style="margin-bottom:6px;">جمع‌بندی</h3>
                        <p style="font-size:13px;">@summaryText</p>
                    </div>
                </div>
            }
            <div class="page-footer"><span class="brand">ANA — Behavior Intelligence</span><span>@reportCode</span></div>
        </div>
    }

    @if (_model.KeyMoments.Any())
    {
        pageNumber++;
        var momentIcons = new[] { "\U0001F4DD", "\U0001F9E0", "\U0001F465", "\U0001F4BC", "\U0001F91D", "\U0001F4AC" };
        var session = report.GameSession;
        int? sessionMinutes = session?.StartTime.HasValue == true && session?.EndTime.HasValue == true
            ? (int)Math.Round((session.EndTime!.Value - session.StartTime!.Value).TotalMinutes)
            : null;
        <div class="report-page">
            <div class="page-header"><span>@gameName | گزارش مشاهده رفتاری</span><span class="page-num">@pageNumber.ToString("00")</span></div>
            <h1 class="page-title">لحظات کلیدی جلسه</h1>
            <p class="page-desc">این تایم‌لاین، رویدادهای مهم و نقاط عطف رفتاری را در طول جلسه نشان می‌دهد. هر لحظه می‌تواند سرنخی برای درک بهتر روند گفتگو و تعاملات باشد.</p>

            <div class="indicator-layout">
                <div class="pattern-aside">
                    <div class="pattern-aside-content">
                        <div class="moment-aside-ring">
                            <div class="moment-aside-ring-inner">🕐</div>
                        </div>
                        <h2>لحظات کلیدی جلسه</h2>
                        <div class="aside-divider"></div>
                        @if (sessionMinutes.HasValue)
                        {
                            <div class="score-caption">مدت جلسه</div>
                            <div class="score">@sessionMinutes</div>
                            <div class="score-caption">دقیقه</div>
                            <div class="aside-divider"></div>
                        }
                        <div class="indicator-quote-box">
                            <div class="quote-mark">❝</div>
                            <p>هر تعامل، داستانی از رفتار و تصمیم است. این لحظات کلیدی نشان می‌دهند که چگونه گفتگو پیش رفت و چه عواملی بر نتیجه تأثیر گذاشتند.</p>
                        </div>
                    </div>
                    <svg class="pattern-aside-waves" viewBox="0 0 800 220" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0,120 C150,180 300,60 450,110 C600,160 700,90 800,130 L800,220 L0,220 Z" fill="#eaf6f4" />
                        <path d="M0,150 C180,90 320,190 500,140 C650,100 720,170 800,150 L800,220 L0,220 Z" fill="#d7efec" />
                        <path d="M0,180 C200,140 350,210 550,170 C680,145 730,200 800,180 L800,220 L0,220 Z" fill="#2a9d8f" opacity="0.35" />
                    </svg>
                </div>

                <div class="indicator-main">
                    @foreach (var (m, mi) in _model.KeyMoments.Select((m, idx) => (m, idx)))
                    {
                        var ms = m.KeyMoment?.TimestampMs ?? 0;
                        var ts = TimeSpan.FromMilliseconds(ms);
                        var absoluteTime = session?.StartTime.HasValue == true ? session.StartTime!.Value.Add(ts) : (DateTime?)null;
                        <div class="moment-card">
                            <div class="moment-card-icon">@momentIcons[mi % momentIcons.Length]</div>
                            <div class="moment-card-body">
                                <div class="moment-card-top">
                                    <span class="moment-card-time">@(absoluteTime?.ToString("HH:mm") ?? ts.ToString(@"mm\:ss"))</span>
                                    <span class="moment-card-title">@m.KeyMoment?.Title</span>
                                </div>
                                <div class="moment-card-desc">@(m.NarrativeText ?? m.KeyMoment?.Description)</div>
                            </div>
                            <div class="moment-card-num-wrap">
                                <div class="moment-card-num">@((mi + 1).ToString("00"))</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="page-footer"><span class="brand">ANA — Behavior Intelligence</span><span>@reportCode</span></div>
        </div>
    }

    @if (_model.GrowthMapEntries.Any() || _model.ActionPlanItems.Any())
    {
        pageNumber++;
        var overallIndAvg = _model.IndicatorScores.Any() ? _model.IndicatorScores.Average(s => s.ScoreValue) : 0;
        var overallIndMax = _model.IndicatorScores.Any() ? _model.IndicatorScores.Max(s => s.ScoringScale?.MaxValue ?? 5m) : 5m;
        var overallLevel = ReportPrintViewModel.GetLevel(overallIndAvg, overallIndMax);
        var (overallLevelLabel, overallLevelColor) = ReportPrintViewModel.GetLevelInfo(overallLevel);
        var overallFilledDots = overallIndMax > 0 ? (int)Math.Round((overallIndAvg / overallIndMax) * 5m) : 0;
        var overallPct = overallIndMax > 0 ? (double)(overallIndAvg / overallIndMax) * 100 : 0;
        var finalSummaryText = _model.PatternScores.FirstOrDefault(p => p.IsDominantPattern && !string.IsNullOrWhiteSpace(p.Description))?.Description
            ?? _model.PatternScores.FirstOrDefault(p => !string.IsNullOrWhiteSpace(p.Description))?.Description;
        <div class="report-page">
            <div class="page-header"><span>@gameName | گزارش مشاهده رفتاری</span><span class="page-num">@pageNumber.ToString("00")</span></div>
            <h1 class="page-title">نقشه رشد</h1>
            <p class="page-desc">با توجه به تحلیل رفتارهای @participantName در این جلسه، مسیر رشد در بخش‌های زیر خلاصه شده است. از این نقشه برای تقویت نقاط قوت و رشد هدفمند استفاده کنید.</p>

            <div class="indicator-layout">
                <div class="pattern-aside">
                    <div class="pattern-aside-content">
                        <div class="indicator-icon-circle">🧭</div>
                        <h2>نقشه رشد</h2>
                        <div class="aside-divider"></div>
                        <div class="score-caption">امتیاز شما</div>
                        <div class="score">@overallIndAvg.ToString("0.0") <small>/@overallIndMax.ToString("0.#")</small></div>
                        <div class="score-bar-track"><div class="score-bar-fill" style="width:@(overallPct)%;"></div></div>
                        <div class="dots">
                            @for (int i = 0; i < 5; i++)
                            {
                                <span class="@(i < overallFilledDots ? "dot filled" : "dot")"></span>
                            }
                        </div>
                        <div class="score-caption" style="margin-top:10px;">سطح کلی</div>
                        <div class="level-plain" style="color:@overallLevelColor;">@overallLevelLabel</div>
                        <div class="indicator-quote-box">
                            <div class="quote-mark">❝</div>
                            <p>رشد، یک مسیر مداوم است. با تمرکز بر آگاهی، تمرین و بازخورد، هر تعامل شما را یک قدم به نسخه بهتر خود نزدیک‌تر می‌کند.</p>
                        </div>
                        <div class="info-callout" style="max-width:none; margin-top:14px;">
                            <span>ℹ️</span>
                            <span>این نقشه بر اساس مشاهده رفتارهای شما در طول این جلسه تهیه شده است و می‌تواند در تعاملات آینده به‌روز شود.</span>
                        </div>
                    </div>
                    <svg class="pattern-aside-waves" viewBox="0 0 800 220" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0,120 C150,180 300,60 450,110 C600,160 700,90 800,130 L800,220 L0,220 Z" fill="#eaf6f4" />
                        <path d="M0,150 C180,90 320,190 500,140 C650,100 720,170 800,150 L800,220 L0,220 Z" fill="#d7efec" />
                        <path d="M0,180 C200,140 350,210 550,170 C680,145 730,200 800,180 L800,220 L0,220 Z" fill="#2a9d8f" opacity="0.35" />
                    </svg>
                </div>

                <div class="indicator-main">
                    @if (_model.GrowthMapEntries.Any())
                    {
                        <div class="growth-cols">
                            @foreach (var g in _model.GrowthMapEntries)
                            {
                                var (gIcon, gColor) = ReportPrintViewModel.GetGrowthColumnStyle(g.Area);
                                var gCaption = ReportPrintViewModel.GetGrowthColumnCaption(g.Area);
                                var (fIcon, fTone, fText) = ReportPrintViewModel.GetGrowthColumnFooter(g.Area);
                                var growthLines = new[] { g.CurrentState, g.TargetState }
                                    .Where(s => !string.IsNullOrWhiteSpace(s))
                                    .SelectMany(s => s!.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                                    .Select(s => s.Trim())
                                    .ToList();
                                <div class="growth-col" style="border-top-color:@gColor;">
                                    <div class="growth-col-header">
                                        <div class="growth-col-icon" style="background:@gColor;">@gIcon</div>
                                        <h4>@g.Area</h4>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(gCaption))
                                    {
                                        <div class="growth-col-caption">@gCaption</div>
                                    }
                                    <div class="growth-col-divider"></div>
                                    @if (growthLines.Any())
                                    {
                                        <ul class="growth-list">
                                            @foreach (var line in growthLines)
                                            {
                                                <li>@line</li>
                                            }
                                        </ul>
                                    }
                                    <div class="growth-col-footer @fTone">
                                        <span>@fIcon</span>
                                        <span>@fText</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    @if (_model.ActionPlanItems.Any())
                    {
                        <div class="card-box" style="margin-top:20px;">
                            <h3>✅ برنامه اقدام</h3>
                            @foreach (var a in _model.ActionPlanItems)
                            {
                                <div class="growth-entry">
                                    <span class="priority-badge priority-@(a.Priority ?? "Medium")">@a.Priority</span>
                                    @a.ActionDescription
                                    @if (!string.IsNullOrWhiteSpace(a.TimeFrame))
                                    {
                                        <span style="color:#999;font-size:11px;"> (@a.TimeFrame)</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(finalSummaryText))
                    {
                        <div class="card-box" style="margin-top:20px; display:flex; align-items:flex-start; gap:16px;">
                            <div class="summary-icon-box">📋</div>
                            <div>
                                <h3 style="margin-bottom:6px;">جمع‌بندی نهایی</h3>
                                <p style="font-size:13px;">@finalSummaryText</p>
                            </div>
                        </div>
                    }
                    <div class="card-box" style="margin-top:20px; display:flex; align-items:flex-start; gap:16px;">
                        <div class="summary-icon-box">💬</div>
                        <div>
                            <h3 style="margin-bottom:6px;">پیام نهایی سلوا</h3>
                            <p style="font-size:13px;">هر گفتگو فرصتی است برای شناخت بهتر خود و دیگران. با آگاهی، تمرین و بازخورد مستمر، می‌توانید در هر تعامل یک قدم به نسخه بهتر خود نزدیک‌تر شوید.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="page-footer"><span class="brand">ANA — Behavior Intelligence</span><span>@reportCode</span></div>
        </div>
    }

    @((MarkupString)ChartScript)
}

@code {
    [Parameter] public long Id { get; set; }
    private ReportPrintViewModel? _model;

    private string ChartScript
    {
        get
        {
            var labels = string.Join(",", _model!.IndicatorScores.Select(s => $"\"{s.IndicatorDefinition?.Title}\""));
            var data = string.Join(",", _model.IndicatorScores.Select(s => s.ScoreValue.ToString(CultureInfo.InvariantCulture)));
            var max = _model.IndicatorScores.Any() ? _model.IndicatorScores.Max(s => s.ScoringScale?.MaxValue ?? 5m) : 5m;
            var sb = new System.Text.StringBuilder();
            sb.Append("<script>(function () {");
            sb.Append("var ctx = document.getElementById('radarChart');");
            sb.Append("if (ctx && window.Chart) {");
            sb.Append("new Chart(ctx, {");
            sb.Append("type: 'radar',");
            sb.Append("data: { labels: [").Append(labels).Append("],");
            sb.Append("datasets: [{ label: 'امتیاز', data: [").Append(data).Append("],");
            sb.Append("fill: true, backgroundColor: 'rgba(42,157,143,0.25)', borderColor: '#2a9d8f', pointBackgroundColor: '#2a9d8f' }] },");
            sb.Append("options: { scales: { r: { min: 0, max: ").Append(max.ToString(CultureInfo.InvariantCulture)).Append(", ticks: { stepSize: 1 }, pointLabels: { display: false } } },");
            sb.Append("plugins: { legend: { display: false } } }");
            sb.Append("});");
            sb.Append("}");
            sb.Append("})();</script>");
            return sb.ToString();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        var report = await context.Reports
            .Include(x => x.Organization)
            .Include(x => x.Participant)
            .Include(x => x.Team)
            .Include(x => x.GameSession)
            .Include(x => x.GameVersion).ThenInclude(x => x.Game)
            .Include(x => x.ReportTemplate)
            .FirstOrDefaultAsync(x => x.ReportId == Id);
        if (report == null) return;

        _model = new ReportPrintViewModel
        {
            Report = report,
            IndicatorScores = await context.ReportIndicatorScores
                .Include(x => x.IndicatorDefinition).ThenInclude(x => x.ScoringScale)
                .Where(x => x.ReportId == Id)
                .OrderBy(x => x.IndicatorDefinition.DisplayOrder)
                .ToListAsync(),
            PatternScores = await context.ReportPatternScores
                .Include(x => x.BehavioralPattern)
                .Where(x => x.ReportId == Id)
                .OrderByDescending(x => x.ScoreValue)
                .ToListAsync(),
            KeyMoments = await context.ReportKeyMoments
                .Include(x => x.KeyMoment)
                .Where(x => x.ReportId == Id)
                .OrderBy(x => x.DisplayOrder)
                .ToListAsync(),
            GrowthMapEntries = await context.GrowthMapEntries
                .Where(x => x.ReportId == Id)
                .OrderBy(x => x.DisplayOrder)
                .ToListAsync(),
            ActionPlanItems = await context.ActionPlanItems
                .Where(x => x.ReportId == Id)
                .OrderBy(x => x.DisplayOrder)
                .ToListAsync(),
        };
    }
}
