@typeparam TEntity where TEntity : class
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject EntityMetadataService MetadataService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@if (_metadata == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudDataGrid @ref="_dataGrid" T="TEntity" ServerData="ServerReloadAsync" Filterable="false" Hover="true">
        <ToolBarContent>
            <MudText Typo="Typo.h6">@Registration.DisplayLabel</MudText>
            <MudSpacer />
            <MudTextField T="string" ValueChanged="OnSearch" Placeholder="Search" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       Href="@($"/entities/{Registration.Name}/create")" Class="ml-4">
                New
            </MudButton>
        </ToolBarContent>
        <Columns>
            @foreach (var prop in _metadata.Properties)
            {
                @if (prop.Name == "LogoPath")
                {
                    <TemplateColumn Title="@prop.Name" Sortable="false">
                        <CellTemplate>
                            @{ var logoUrl = (string?)prop.ClrProperty.GetValue(context.Item); }
                            @if (!string.IsNullOrEmpty(logoUrl))
                            {
                                <MudAvatar Square="true" Size="Size.Medium">
                                    <MudImage Src="@logoUrl" ObjectFit="ObjectFit.Contain" />
                                </MudAvatar>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                }
                else
                {
                    <TemplateColumn Title="@prop.Name" Sortable="true" SortBy="@(GetSortSelector(prop))">
                        <CellTemplate>@FormatValue(context.Item, prop)</CellTemplate>
                    </TemplateColumn>
                }
            }
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                   Href="@($"/entities/{Registration.Name}/details/{GetId(context.Item)}")">View</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                   Href="@($"/entities/{Registration.Name}/edit/{GetId(context.Item)}")">Edit</MudButton>
                        @if (Registration.Name == "Report")
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                                       Href="@($"/reports/{GetId(context.Item)}/print")" Target="_blank">Print</MudButton>
                        }
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                   OnClick="@(() => DeleteAsync(context.Item))">Delete</MudButton>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="TEntity" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    private MudDataGrid<TEntity>? _dataGrid;
    private EntityMetadata? _metadata;
    private string? _searchString;
    private EntityRegistration Registration => EntityRegistry.Resolve(typeof(TEntity).Name)!;

    protected override void OnInitialized()
    {
        _metadata = MetadataService.GetMetadata(typeof(TEntity));
    }

    // Dynamic column -> stable string key used by GridState.SortDefinitions; resolved back to
    // the PropertyDescriptor by name in ServerReloadAsync since properties aren't known at compile time.
    private Func<TEntity, object> GetSortSelector(PropertyDescriptor prop) =>
        entity => prop.ClrProperty.GetValue(entity) ?? "";

    private async Task<GridData<TEntity>> ServerReloadAsync(GridState<TEntity> state)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        IEnumerable<TEntity> items = context.Set<TEntity>().ToList();

        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            items = items.Where(e => _metadata!.Properties.Any(p =>
            {
                var val = p.ClrProperty.GetValue(e);
                return val != null && val.ToString()!.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
            }));
        }

        var totalItems = items.Count();

        var sortDefinition = state.SortDefinitions.FirstOrDefault();
        if (sortDefinition != null)
        {
            var prop = _metadata!.Properties.FirstOrDefault(p => p.Name == sortDefinition.SortBy);
            if (prop != null)
            {
                items = sortDefinition.Descending
                    ? items.OrderByDescending(e => prop.ClrProperty.GetValue(e), Comparer<object>.Create((a, b) => System.Collections.Comparer.Default.Compare(a, b)))
                    : items.OrderBy(e => prop.ClrProperty.GetValue(e), Comparer<object>.Create((a, b) => System.Collections.Comparer.Default.Compare(a, b)));
            }
        }

        var pagedData = items.Skip(state.Page * state.PageSize).Take(state.PageSize).ToArray();
        return new GridData<TEntity> { TotalItems = totalItems, Items = pagedData };
    }

    private Task OnSearch(string text)
    {
        _searchString = text;
        return _dataGrid!.ReloadServerData();
    }

    private object? GetId(TEntity entity) => _metadata!.PrimaryKeyProperty.GetValue(entity);

    private string FormatValue(TEntity entity, PropertyDescriptor prop)
    {
        var value = prop.ClrProperty.GetValue(entity);
        if (value == null) return "";
        if (prop.IsForeignKey && prop.PrincipalType != null)
        {
            using var context = DbFactory.CreateDbContext();
            var principal = context.Find(prop.PrincipalType, value);
            if (principal != null)
                return EntityMetadataService.GetDisplayText(principal, prop);
        }
        return value.ToString() ?? "";
    }

    private async Task DeleteAsync(TEntity entity)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete", $"Delete this {Registration.DisplayLabel}?", yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;

        using var context = await DbFactory.CreateDbContextAsync();
        var id = GetId(entity);
        var tracked = await context.FindAsync<TEntity>(id);
        if (tracked == null) return;

        try
        {
            context.Remove(tracked);
            await context.SaveChangesAsync();
            Snackbar.Add("Deleted.", Severity.Success);
            await _dataGrid!.ReloadServerData();
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add(Helpers.DbExceptionHelper.GetFriendlyMessage(ex), Severity.Error);
        }
    }
}
