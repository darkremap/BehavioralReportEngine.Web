<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    @foreach (var group in EntityRegistry.All.GroupBy(e => e.NavGroup))
    {
        <MudNavGroup Title="@group.Key" Expanded="false"
                     Icon="@EntityRegistry.NavGroupIcons.GetValueOrDefault(group.Key, Icons.Material.Filled.Folder)">
            @foreach (var entity in group)
            {
                <MudNavLink Href="@($"/entities/{entity.Name}")" Icon="@entity.Icon">@entity.DisplayLabel</MudNavLink>
            }
        </MudNavGroup>
    }
</MudNavMenu>
