@model IEnumerable<BehavioralReportEngine.Web.Models.GameSession>

@{
    ViewData["Title"] = "GameSession List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Game Session</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Game Session</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.SessionCode)</th>
            <th>@Html.DisplayNameFor(model => model.SessionName)</th>
            <th>@Html.DisplayNameFor(model => model.SessionDate)</th>
            <th>@Html.DisplayNameFor(model => model.StartTime)</th>
            <th>@Html.DisplayNameFor(model => model.EndTime)</th>
            <th>@Html.DisplayNameFor(model => model.Location)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>Organization</th>
            <th>GameVersion</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.SessionCode</td>
                <td>@item.SessionName</td>
                <td>@item.SessionDate.ToString("g")</td>
                <td>@item.StartTime?.ToString("g")</td>
                <td>@item.EndTime?.ToString("g")</td>
                <td>@item.Location</td>
                <td>@item.Status</td>
                <td>@item.Organization?.Name</td>
                <td>@item.GameVersion?.VersionNumber</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.SessionId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.SessionId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.SessionId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
