@model IEnumerable<BehavioralReportEngine.Web.Models.AppUser>

@{
    ViewData["Title"] = "AppUser List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>App User</h2>
    <a asp-action="Create" class="btn btn-primary">+ New App User</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.FullName)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>@Html.DisplayNameFor(model => model.IsActive)</th>
            <th>Organization</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@(item.IsActive ? "Yes" : "No")</td>
                <td>@item.Organization?.Name</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
