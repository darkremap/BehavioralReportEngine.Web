@model BehavioralReportEngine.Web.Models.AppUser

@{
    ViewData["Title"] = "Delete AppUser";
}

<h2>Delete App User</h2>

<div class="alert alert-warning">Are you sure you want to delete this app user?</div>

<dl class="row">
    <dt class="col-sm-3">Organization</dt>
    <dd class="col-sm-9">@Model.Organization?.Name</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.FullName)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.FullName)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Email)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Email)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.IsActive)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.IsActive)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="UserId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
