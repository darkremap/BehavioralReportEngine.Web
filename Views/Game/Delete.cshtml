@model BehavioralReportEngine.Web.Models.Game

@{
    ViewData["Title"] = "Delete Game";
}

<h2>Delete Game</h2>

<div class="alert alert-warning">Are you sure you want to delete this game?</div>

<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.GameCode)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.GameCode)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.NameFa)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.NameFa)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.NameEn)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.NameEn)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Summary)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Summary)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.TitleFa)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.TitleFa)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.TitleEn)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.TitleEn)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.DescriptionFa)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.DescriptionFa)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.DescriptionEn)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.DescriptionEn)</dd>
<dt class="col-sm-3">App User</dt>
    <dd class="col-sm-9">@Model.AppUser?.FullName</dd>
<dt class="col-sm-3">Game Type</dt>
    <dd class="col-sm-9">@Model.GameType?.NameFa</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.DurationMinutes)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.DurationMinutes)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.IsActive)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.IsActive)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="GameId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
