@model BehavioralReportEngine.Web.Models.ScoringScaleLevel

@{
    ViewData["Title"] = "Create ScoringScaleLevel";
}

<h2>Create Scoring Scale Level</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="ScoringScaleId" class="form-label"></label>
                <select asp-for="ScoringScaleId" class="form-select" asp-items="ViewBag.ScoringScaleId"></select>
                <span asp-validation-for="ScoringScaleId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LevelValue" class="form-label"></label>
                <input asp-for="LevelValue" class="form-control" />
                <span asp-validation-for="LevelValue" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LevelLabel" class="form-label"></label>
                <input asp-for="LevelLabel" class="form-control" />
                <span asp-validation-for="LevelLabel" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LevelDescription" class="form-label"></label>
                <textarea asp-for="LevelDescription" class="form-control" rows="3"></textarea>
                <span asp-validation-for="LevelDescription" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
