@model IEnumerable<BehavioralReportEngine.Web.Models.ScoringScaleLevel>

@{
    ViewData["Title"] = "ScoringScaleLevel List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Scoring Scale Level</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Scoring Scale Level</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.LevelValue)</th>
            <th>@Html.DisplayNameFor(model => model.LevelLabel)</th>
            <th>@Html.DisplayNameFor(model => model.LevelDescription)</th>
            <th>ScoringScale</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.LevelValue</td>
                <td>@item.LevelLabel</td>
                <td>@item.LevelDescription</td>
                <td>@item.ScoringScale?.Name</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.ScoringScaleLevelId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.ScoringScaleLevelId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.ScoringScaleLevelId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
