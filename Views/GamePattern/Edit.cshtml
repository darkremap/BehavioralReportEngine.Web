@model BehavioralReportEngine.Web.Models.GamePattern

@{
    ViewData["Title"] = "Edit GamePattern";
}

<h2>Edit Game Pattern</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="GamePatternId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="GameVersionId" class="form-label"></label>
                <select asp-for="GameVersionId" class="form-select" asp-items="ViewBag.GameVersionId"></select>
                <span asp-validation-for="GameVersionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="BehavioralPatternId" class="form-label"></label>
                <select asp-for="BehavioralPatternId" class="form-select" asp-items="ViewBag.BehavioralPatternId"></select>
                <span asp-validation-for="BehavioralPatternId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CustomName" class="form-label"></label>
                <input asp-for="CustomName" class="form-control" />
                <span asp-validation-for="CustomName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CustomDescription" class="form-label"></label>
                <textarea asp-for="CustomDescription" class="form-control" rows="3"></textarea>
                <span asp-validation-for="CustomDescription" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DisplayOrder" class="form-label"></label>
                <input asp-for="DisplayOrder" class="form-control" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
