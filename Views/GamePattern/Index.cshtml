@model IEnumerable<BehavioralReportEngine.Web.Models.GamePattern>

@{
    ViewData["Title"] = "GamePattern List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Game Pattern</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Game Pattern</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.CustomName)</th>
            <th>@Html.DisplayNameFor(model => model.CustomDescription)</th>
            <th>@Html.DisplayNameFor(model => model.DisplayOrder)</th>
            <th>GameVersion</th>
            <th>BehavioralPattern</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.CustomName</td>
                <td>@item.CustomDescription</td>
                <td>@item.DisplayOrder</td>
                <td>@item.GameVersion?.VersionNumber</td>
                <td>@item.BehavioralPattern?.NameEn</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.GamePatternId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.GamePatternId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.GamePatternId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
