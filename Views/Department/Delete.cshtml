@model BehavioralReportEngine.Web.Models.Department

@{
    ViewData["Title"] = "Delete Department";
}

<h2>Delete Department</h2>

<div class="alert alert-warning">Are you sure you want to delete this department?</div>

<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.DepartmentCode)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.DepartmentCode)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.NameFa)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.NameFa)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.NameEn)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.NameEn)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Description)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Description)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.IsActive)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.IsActive)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="DepartmentId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
