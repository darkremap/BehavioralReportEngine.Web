@model IEnumerable<BehavioralReportEngine.Web.Models.UserRole>

@{
    ViewData["Title"] = "UserRole List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>User Role</h2>
    <a asp-action="Create" class="btn btn-primary">+ New User Role</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.RoleCode)</th>
            <th>@Html.DisplayNameFor(model => model.RoleName)</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.RoleCode</td>
                <td>@item.RoleName</td>
                <td>@item.Description</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.RoleId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.RoleId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.RoleId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
