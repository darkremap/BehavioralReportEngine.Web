@model IEnumerable<BehavioralReportEngine.Web.Models.ReportTemplate>

@{
    ViewData["Title"] = "ReportTemplate List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Report Template</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Report Template</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.ReportScope)</th>
            <th>@Html.DisplayNameFor(model => model.TemplateName)</th>
            <th>@Html.DisplayNameFor(model => model.VersionNumber)</th>
            <th>@Html.DisplayNameFor(model => model.IsActive)</th>
            <th>GameVersion</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.ReportScope</td>
                <td>@item.TemplateName</td>
                <td>@item.VersionNumber</td>
                <td>@(item.IsActive ? "Yes" : "No")</td>
                <td>@item.GameVersion?.VersionNumber</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.ReportTemplateId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.ReportTemplateId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.ReportTemplateId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
