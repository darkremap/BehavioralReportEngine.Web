@model IEnumerable<BehavioralReportEngine.Web.Models.Team>

@{
    ViewData["Title"] = "Team List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Team</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Team</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.TeamName)</th>
            <th>@Html.DisplayNameFor(model => model.TeamCode)</th>
            <th>GameSession</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.TeamName</td>
                <td>@item.TeamCode</td>
                <td>@item.GameSession?.SessionName</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.TeamId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.TeamId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.TeamId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
