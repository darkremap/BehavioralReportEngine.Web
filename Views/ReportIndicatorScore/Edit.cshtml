@model BehavioralReportEngine.Web.Models.ReportIndicatorScore

@{
    ViewData["Title"] = "Edit ReportIndicatorScore";
}

<h2>Edit Report Indicator Score</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ReportIndicatorScoreId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="ReportId" class="form-label"></label>
                <select asp-for="ReportId" class="form-select" asp-items="ViewBag.ReportId"></select>
                <span asp-validation-for="ReportId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IndicatorDefinitionId" class="form-label"></label>
                <select asp-for="IndicatorDefinitionId" class="form-select" asp-items="ViewBag.IndicatorDefinitionId"></select>
                <span asp-validation-for="IndicatorDefinitionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ScoreValue" class="form-label"></label>
                <input asp-for="ScoreValue" class="form-control" />
                <span asp-validation-for="ScoreValue" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ScoringScaleId" class="form-label"></label>
                <select asp-for="ScoringScaleId" class="form-select" asp-items="ViewBag.ScoringScaleId"></select>
                <span asp-validation-for="ScoringScaleId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ObservedEvidence" class="form-label"></label>
                <textarea asp-for="ObservedEvidence" class="form-control" rows="3"></textarea>
                <span asp-validation-for="ObservedEvidence" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IndicatorBehaviors" class="form-label"></label>
                <textarea asp-for="IndicatorBehaviors" class="form-control" rows="3"></textarea>
                <span asp-validation-for="IndicatorBehaviors" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="GrowthOpportunities" class="form-label"></label>
                <textarea asp-for="GrowthOpportunities" class="form-control" rows="3"></textarea>
                <span asp-validation-for="GrowthOpportunities" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Strengths" class="form-label"></label>
                <textarea asp-for="Strengths" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Strengths" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="PracticalRecommendation" class="form-label"></label>
                <textarea asp-for="PracticalRecommendation" class="form-control" rows="3"></textarea>
                <span asp-validation-for="PracticalRecommendation" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="IsAiGenerated" class="form-check-input" />
                <label class="form-check-label" asp-for="IsAiGenerated"></label>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
