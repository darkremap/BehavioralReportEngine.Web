@model IEnumerable<BehavioralReportEngine.Web.Models.ReportIndicatorScore>

@{
    ViewData["Title"] = "ReportIndicatorScore List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Report Indicator Score</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Report Indicator Score</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.ScoreValue)</th>
            <th>@Html.DisplayNameFor(model => model.ObservedEvidence)</th>
            <th>@Html.DisplayNameFor(model => model.IndicatorBehaviors)</th>
            <th>@Html.DisplayNameFor(model => model.GrowthOpportunities)</th>
            <th>@Html.DisplayNameFor(model => model.Strengths)</th>
            <th>@Html.DisplayNameFor(model => model.PracticalRecommendation)</th>
            <th>@Html.DisplayNameFor(model => model.IsAiGenerated)</th>
            <th>Report</th>
            <th>IndicatorDefinition</th>
            <th>ScoringScale</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.ScoreValue</td>
                <td>@item.ObservedEvidence</td>
                <td>@item.IndicatorBehaviors</td>
                <td>@item.GrowthOpportunities</td>
                <td>@item.Strengths</td>
                <td>@item.PracticalRecommendation</td>
                <td>@(item.IsAiGenerated ? "Yes" : "No")</td>
                <td>@item.Report?.ReportTitle</td>
                <td>@item.IndicatorDefinition?.TitleEn</td>
                <td>@item.ScoringScale?.Name</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.ReportIndicatorScoreId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.ReportIndicatorScoreId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.ReportIndicatorScoreId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
