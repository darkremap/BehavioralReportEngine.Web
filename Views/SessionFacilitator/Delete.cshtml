@model BehavioralReportEngine.Web.Models.SessionFacilitator

@{
    ViewData["Title"] = "Delete SessionFacilitator";
}

<h2>Delete Session Facilitator</h2>

<div class="alert alert-warning">Are you sure you want to delete this session facilitator?</div>

<dl class="row">
    <dt class="col-sm-3">Game Session</dt>
    <dd class="col-sm-9">@Model.GameSession?.SessionName</dd>
<dt class="col-sm-3">App User</dt>
    <dd class="col-sm-9">@Model.AppUser?.FullName</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.RoleInSession)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.RoleInSession)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="SessionFacilitatorId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
