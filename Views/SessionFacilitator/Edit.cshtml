@model BehavioralReportEngine.Web.Models.SessionFacilitator

@{
    ViewData["Title"] = "Edit SessionFacilitator";
}

<h2>Edit Session Facilitator</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="SessionFacilitatorId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="SessionId" class="form-label"></label>
                <select asp-for="SessionId" class="form-select" asp-items="ViewBag.SessionId"></select>
                <span asp-validation-for="SessionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="UserId" class="form-label"></label>
                <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId"></select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="RoleInSession" class="form-label"></label>
                <input asp-for="RoleInSession" class="form-control" />
                <span asp-validation-for="RoleInSession" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
