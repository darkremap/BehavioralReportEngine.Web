@model IEnumerable<BehavioralReportEngine.Web.Models.AppUserRole>

@{
    ViewData["Title"] = "AppUserRole List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>App User Role</h2>
    <a asp-action="Create" class="btn btn-primary">+ New App User Role</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>AppUser</th>
            <th>UserRole</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.AppUser?.FullName</td>
                <td>@item.UserRole?.RoleName</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.AppUserRoleId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.AppUserRoleId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.AppUserRoleId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
