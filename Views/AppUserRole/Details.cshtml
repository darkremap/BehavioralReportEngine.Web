@model BehavioralReportEngine.Web.Models.AppUserRole

@{
    ViewData["Title"] = "AppUserRole Details";
}

<h2>App User Role Details</h2>

<dl class="row">
    <dt class="col-sm-3">App User</dt>
    <dd class="col-sm-9">@Model.AppUser?.FullName</dd>
<dt class="col-sm-3">User Role</dt>
    <dd class="col-sm-9">@Model.UserRole?.RoleName</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.AppUserRoleId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
