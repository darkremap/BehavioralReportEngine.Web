@model BehavioralReportEngine.Web.Models.AppUserRole

@{
    ViewData["Title"] = "Delete AppUserRole";
}

<h2>Delete App User Role</h2>

<div class="alert alert-warning">Are you sure you want to delete this app user role?</div>

<dl class="row">
    <dt class="col-sm-3">App User</dt>
    <dd class="col-sm-9">@Model.AppUser?.FullName</dd>
<dt class="col-sm-3">User Role</dt>
    <dd class="col-sm-9">@Model.UserRole?.RoleName</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="AppUserRoleId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
