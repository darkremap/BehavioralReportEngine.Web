@model BehavioralReportEngine.Web.Models.IndicatorDefinition

@{
    ViewData["Title"] = "Create IndicatorDefinition";
}

<h2>Create Indicator Definition</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="GameVersionId" class="form-label"></label>
                <select asp-for="GameVersionId" class="form-select" asp-items="ViewBag.GameVersionId"></select>
                <span asp-validation-for="GameVersionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IndicatorCode" class="form-label"></label>
                <input asp-for="IndicatorCode" class="form-control" />
                <span asp-validation-for="IndicatorCode" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TitleEn" class="form-label"></label>
                <input asp-for="TitleEn" class="form-control" />
                <span asp-validation-for="TitleEn" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ShortDefinition" class="form-label"></label>
                <textarea asp-for="ShortDefinition" class="form-control" rows="3"></textarea>
                <span asp-validation-for="ShortDefinition" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DisplayOrder" class="form-label"></label>
                <input asp-for="DisplayOrder" class="form-control" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ScoringScaleId" class="form-label"></label>
                <select asp-for="ScoringScaleId" class="form-select" asp-items="ViewBag.ScoringScaleId"></select>
                <span asp-validation-for="ScoringScaleId" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label class="form-check-label" asp-for="IsActive"></label>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
