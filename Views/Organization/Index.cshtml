@model IEnumerable<BehavioralReportEngine.Web.Models.Organization>

@{
    ViewData["Title"] = "Organization List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Organization</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Organization</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.OrganizationCode)</th>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Industry)</th>
            <th>@Html.DisplayNameFor(model => model.Country)</th>
            <th>@Html.DisplayNameFor(model => model.IsActive)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.OrganizationCode</td>
                <td>@item.Name</td>
                <td>@item.Industry</td>
                <td>@item.Country</td>
                <td>@(item.IsActive ? "Yes" : "No")</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.OrganizationId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.OrganizationId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.OrganizationId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
