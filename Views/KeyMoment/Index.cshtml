@model IEnumerable<BehavioralReportEngine.Web.Models.KeyMoment>

@{
    ViewData["Title"] = "KeyMoment List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Key Moment</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Key Moment</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.TimestampMs)</th>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>@Html.DisplayNameFor(model => model.Significance)</th>
            <th>GameSession</th>
            <th>Team</th>
            <th>Participant</th>
            <th>MediaAsset</th>
            <th>TranscriptSegment</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.TimestampMs</td>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td>@item.Significance</td>
                <td>@item.GameSession?.SessionName</td>
                <td>@item.Team?.TeamName</td>
                <td>@item.Participant?.FirstNameFa</td>
                <td>@item.MediaAsset?.FileName</td>
                <td>@item.TranscriptSegment?.TranscriptSegmentId</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.KeyMomentId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.KeyMomentId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.KeyMomentId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
