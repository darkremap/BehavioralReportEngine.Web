@model BehavioralReportEngine.Web.Models.KeyMoment

@{
    ViewData["Title"] = "Create KeyMoment";
}

<h2>Create Key Moment</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="SessionId" class="form-label"></label>
                <select asp-for="SessionId" class="form-select" asp-items="ViewBag.SessionId"></select>
                <span asp-validation-for="SessionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TeamId" class="form-label"></label>
                <select asp-for="TeamId" class="form-select" asp-items="ViewBag.TeamId"><option value="">-- None --</option></select>
                <span asp-validation-for="TeamId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ParticipantId" class="form-label"></label>
                <select asp-for="ParticipantId" class="form-select" asp-items="ViewBag.ParticipantId"><option value="">-- None --</option></select>
                <span asp-validation-for="ParticipantId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="MediaAssetId" class="form-label"></label>
                <select asp-for="MediaAssetId" class="form-select" asp-items="ViewBag.MediaAssetId"><option value="">-- None --</option></select>
                <span asp-validation-for="MediaAssetId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TranscriptSegmentId" class="form-label"></label>
                <select asp-for="TranscriptSegmentId" class="form-select" asp-items="ViewBag.TranscriptSegmentId"><option value="">-- None --</option></select>
                <span asp-validation-for="TranscriptSegmentId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TimestampMs" class="form-label"></label>
                <input asp-for="TimestampMs" class="form-control" />
                <span asp-validation-for="TimestampMs" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Significance" class="form-label"></label>
                <textarea asp-for="Significance" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Significance" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
