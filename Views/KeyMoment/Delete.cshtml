@model BehavioralReportEngine.Web.Models.KeyMoment

@{
    ViewData["Title"] = "Delete KeyMoment";
}

<h2>Delete Key Moment</h2>

<div class="alert alert-warning">Are you sure you want to delete this key moment?</div>

<dl class="row">
    <dt class="col-sm-3">Game Session</dt>
    <dd class="col-sm-9">@Model.GameSession?.SessionName</dd>
<dt class="col-sm-3">Team</dt>
    <dd class="col-sm-9">@Model.Team?.TeamName</dd>
<dt class="col-sm-3">Participant</dt>
    <dd class="col-sm-9">@Model.Participant?.FirstNameFa</dd>
<dt class="col-sm-3">Media Asset</dt>
    <dd class="col-sm-9">@Model.MediaAsset?.FileName</dd>
<dt class="col-sm-3">Transcript Segment</dt>
    <dd class="col-sm-9">@Model.TranscriptSegment?.TranscriptSegmentId</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.TimestampMs)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.TimestampMs)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Title)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Title)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Description)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Description)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Significance)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Significance)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="KeyMomentId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
