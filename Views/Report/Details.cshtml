@model BehavioralReportEngine.Web.Models.Report

@{
    ViewData["Title"] = "Report Details";
}

<h2>Report Details</h2>

<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ReportScope)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.ReportScope)</dd>
<dt class="col-sm-3">Report Template</dt>
    <dd class="col-sm-9">@Model.ReportTemplate?.TemplateName</dd>
<dt class="col-sm-3">Game Session</dt>
    <dd class="col-sm-9">@Model.GameSession?.SessionName</dd>
<dt class="col-sm-3">Participant</dt>
    <dd class="col-sm-9">@Model.Participant?.FirstNameFa</dd>
<dt class="col-sm-3">Team</dt>
    <dd class="col-sm-9">@Model.Team?.TeamName</dd>
<dt class="col-sm-3">Organization</dt>
    <dd class="col-sm-9">@Model.Organization?.Name</dd>
<dt class="col-sm-3">Game Version</dt>
    <dd class="col-sm-9">@Model.GameVersion?.VersionNumber</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.ReportTitle)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.ReportTitle)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.GeneratedAt)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.GeneratedAt)</dd>
<dt class="col-sm-3">App User</dt>
    <dd class="col-sm-9">@Model.AppUser?.FullName</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.GenerationMethod)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.GenerationMethod)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Status)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Status)</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.ReportId" class="btn btn-primary">Edit</a>
<a asp-action="Print" asp-route-id="@Model.ReportId" target="_blank" class="btn btn-success">چاپ گزارش</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
