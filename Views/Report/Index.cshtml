@model IEnumerable<BehavioralReportEngine.Web.Models.Report>

@{
    ViewData["Title"] = "Report List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Report</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Report</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.ReportScope)</th>
            <th>@Html.DisplayNameFor(model => model.ReportTitle)</th>
            <th>@Html.DisplayNameFor(model => model.GeneratedAt)</th>
            <th>@Html.DisplayNameFor(model => model.GenerationMethod)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>ReportTemplate</th>
            <th>GameSession</th>
            <th>Participant</th>
            <th>Team</th>
            <th>Organization</th>
            <th>GameVersion</th>
            <th>AppUser</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.ReportScope</td>
                <td>@item.ReportTitle</td>
                <td>@item.GeneratedAt?.ToString("g")</td>
                <td>@item.GenerationMethod</td>
                <td>@item.Status</td>
                <td>@item.ReportTemplate?.TemplateName</td>
                <td>@item.GameSession?.SessionName</td>
                <td>@item.Participant?.FirstNameFa</td>
                <td>@item.Team?.TeamName</td>
                <td>@item.Organization?.Name</td>
                <td>@item.GameVersion?.VersionNumber</td>
                <td>@item.AppUser?.FullName</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.ReportId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.ReportId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Print" asp-route-id="@item.ReportId" target="_blank" class="btn btn-sm btn-outline-success">چاپ گزارش</a>
                <a asp-action="Delete" asp-route-id="@item.ReportId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
