@model BehavioralReportEngine.Web.Models.ReportKeyMoment

@{
    ViewData["Title"] = "Edit ReportKeyMoment";
}

<h2>Edit Report Key Moment</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ReportKeyMomentId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="ReportId" class="form-label"></label>
                <select asp-for="ReportId" class="form-select" asp-items="ViewBag.ReportId"></select>
                <span asp-validation-for="ReportId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="KeyMomentId" class="form-label"></label>
                <select asp-for="KeyMomentId" class="form-select" asp-items="ViewBag.KeyMomentId"></select>
                <span asp-validation-for="KeyMomentId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DisplayOrder" class="form-label"></label>
                <input asp-for="DisplayOrder" class="form-control" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="NarrativeText" class="form-label"></label>
                <textarea asp-for="NarrativeText" class="form-control" rows="3"></textarea>
                <span asp-validation-for="NarrativeText" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
