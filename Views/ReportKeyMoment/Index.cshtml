@model IEnumerable<BehavioralReportEngine.Web.Models.ReportKeyMoment>

@{
    ViewData["Title"] = "ReportKeyMoment List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Report Key Moment</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Report Key Moment</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.DisplayOrder)</th>
            <th>@Html.DisplayNameFor(model => model.NarrativeText)</th>
            <th>Report</th>
            <th>KeyMoment</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.DisplayOrder</td>
                <td>@item.NarrativeText</td>
                <td>@item.Report?.ReportTitle</td>
                <td>@item.KeyMoment?.Title</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.ReportKeyMomentId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.ReportKeyMomentId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.ReportKeyMomentId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
