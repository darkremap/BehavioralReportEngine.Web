@model BehavioralReportEngine.Web.Models.ReportKeyMoment

@{
    ViewData["Title"] = "Delete ReportKeyMoment";
}

<h2>Delete Report Key Moment</h2>

<div class="alert alert-warning">Are you sure you want to delete this report key moment?</div>

<dl class="row">
    <dt class="col-sm-3">Report</dt>
    <dd class="col-sm-9">@Model.Report?.ReportTitle</dd>
<dt class="col-sm-3">Key Moment</dt>
    <dd class="col-sm-9">@Model.KeyMoment?.Title</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.DisplayOrder)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.DisplayOrder)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.NarrativeText)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.NarrativeText)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ReportKeyMomentId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
