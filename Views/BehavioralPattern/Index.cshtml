@model IEnumerable<BehavioralReportEngine.Web.Models.BehavioralPattern>

@{
    ViewData["Title"] = "BehavioralPattern List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Behavioral Pattern</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Behavioral Pattern</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.PatternCode)</th>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.NameEn)</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>@Html.DisplayNameFor(model => model.IsGlobal)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.PatternCode</td>
                <td>@item.Name</td>
                <td>@item.NameEn</td>
                <td>@item.Description</td>
                <td>@(item.IsGlobal ? "Yes" : "No")</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.BehavioralPatternId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.BehavioralPatternId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.BehavioralPatternId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
