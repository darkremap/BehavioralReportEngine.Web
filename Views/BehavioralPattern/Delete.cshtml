@model BehavioralReportEngine.Web.Models.BehavioralPattern

@{
    ViewData["Title"] = "Delete BehavioralPattern";
}

<h2>Delete Behavioral Pattern</h2>

<div class="alert alert-warning">Are you sure you want to delete this behavioral pattern?</div>

<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.PatternCode)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.PatternCode)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Name)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Name)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.NameEn)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.NameEn)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Description)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Description)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.IsGlobal)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.IsGlobal)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="BehavioralPatternId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
