@model IEnumerable<BehavioralReportEngine.Web.Models.Participant>

@{
    ViewData["Title"] = "Participant List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Participant</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Participant</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.PersonnelCode)</th>
            <th>@Html.DisplayNameFor(model => model.FirstNameFa)</th>
            <th>@Html.DisplayNameFor(model => model.LastNameFa)</th>
            <th>@Html.DisplayNameFor(model => model.FirstNameEn)</th>
            <th>@Html.DisplayNameFor(model => model.LastNameEn)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>@Html.DisplayNameFor(model => model.BirthDate)</th>
            <th>@Html.DisplayNameFor(model => model.Gender)</th>
            <th>@Html.DisplayNameFor(model => model.JobTitle)</th>
            <th>@Html.DisplayNameFor(model => model.MetadataJson)</th>
            <th>@Html.DisplayNameFor(model => model.IsActive)</th>
            <th>Organization</th>
            <th>Department</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.PersonnelCode</td>
                <td>@item.FirstNameFa</td>
                <td>@item.LastNameFa</td>
                <td>@item.FirstNameEn</td>
                <td>@item.LastNameEn</td>
                <td>@item.Email</td>
                <td>@item.BirthDate?.ToString("g")</td>
                <td>@item.Gender</td>
                <td>@item.JobTitle</td>
                <td>@item.MetadataJson</td>
                <td>@(item.IsActive ? "Yes" : "No")</td>
                <td>@item.Organization?.Name</td>
                <td>@item.Department?.NameFa</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.ParticipantId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.ParticipantId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.ParticipantId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
