@model IEnumerable<BehavioralReportEngine.Web.Models.ReportTemplateModule>

@{
    ViewData["Title"] = "ReportTemplateModule List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Report Template Module</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Report Template Module</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.DisplayOrder)</th>
            <th>@Html.DisplayNameFor(model => model.IsRequired)</th>
            <th>@Html.DisplayNameFor(model => model.ConfigJson)</th>
            <th>ReportTemplate</th>
            <th>ReportModuleType</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.DisplayOrder</td>
                <td>@(item.IsRequired ? "Yes" : "No")</td>
                <td>@item.ConfigJson</td>
                <td>@item.ReportTemplate?.TemplateName</td>
                <td>@item.ReportModuleType?.Name</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.ReportTemplateModuleId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.ReportTemplateModuleId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.ReportTemplateModuleId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
