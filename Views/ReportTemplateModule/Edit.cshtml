@model BehavioralReportEngine.Web.Models.ReportTemplateModule

@{
    ViewData["Title"] = "Edit ReportTemplateModule";
}

<h2>Edit Report Template Module</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ReportTemplateModuleId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="ReportTemplateId" class="form-label"></label>
                <select asp-for="ReportTemplateId" class="form-select" asp-items="ViewBag.ReportTemplateId"></select>
                <span asp-validation-for="ReportTemplateId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ReportModuleTypeId" class="form-label"></label>
                <select asp-for="ReportModuleTypeId" class="form-select" asp-items="ViewBag.ReportModuleTypeId"></select>
                <span asp-validation-for="ReportModuleTypeId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DisplayOrder" class="form-label"></label>
                <input asp-for="DisplayOrder" class="form-control" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="IsRequired" class="form-check-input" />
                <label class="form-check-label" asp-for="IsRequired"></label>
            </div>
            <div class="mb-3">
                <label asp-for="ConfigJson" class="form-label"></label>
                <textarea asp-for="ConfigJson" class="form-control" rows="3"></textarea>
                <span asp-validation-for="ConfigJson" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
