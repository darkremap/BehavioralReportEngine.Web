@model BehavioralReportEngine.Web.Models.ReportPatternScore

@{
    ViewData["Title"] = "Edit ReportPatternScore";
}

<h2>Edit Report Pattern Score</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ReportPatternScoreId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="ReportId" class="form-label"></label>
                <select asp-for="ReportId" class="form-select" asp-items="ViewBag.ReportId"></select>
                <span asp-validation-for="ReportId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="BehavioralPatternId" class="form-label"></label>
                <select asp-for="BehavioralPatternId" class="form-select" asp-items="ViewBag.BehavioralPatternId"></select>
                <span asp-validation-for="BehavioralPatternId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ScoreValue" class="form-label"></label>
                <input asp-for="ScoreValue" class="form-control" />
                <span asp-validation-for="ScoreValue" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="IsDominantPattern" class="form-check-input" />
                <label class="form-check-label" asp-for="IsDominantPattern"></label>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
