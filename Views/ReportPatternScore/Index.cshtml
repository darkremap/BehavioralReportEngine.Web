@model IEnumerable<BehavioralReportEngine.Web.Models.ReportPatternScore>

@{
    ViewData["Title"] = "ReportPatternScore List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Report Pattern Score</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Report Pattern Score</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.ScoreValue)</th>
            <th>@Html.DisplayNameFor(model => model.IsDominantPattern)</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>Report</th>
            <th>BehavioralPattern</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.ScoreValue</td>
                <td>@(item.IsDominantPattern ? "Yes" : "No")</td>
                <td>@item.Description</td>
                <td>@item.Report?.ReportTitle</td>
                <td>@item.BehavioralPattern?.NameEn</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.ReportPatternScoreId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.ReportPatternScoreId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.ReportPatternScoreId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
