@model BehavioralReportEngine.Web.Models.ReportPatternScore

@{
    ViewData["Title"] = "ReportPatternScore Details";
}

<h2>Report Pattern Score Details</h2>

<dl class="row">
    <dt class="col-sm-3">Report</dt>
    <dd class="col-sm-9">@Model.Report?.ReportTitle</dd>
<dt class="col-sm-3">Behavioral Pattern</dt>
    <dd class="col-sm-9">@Model.BehavioralPattern?.NameEn</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.ScoreValue)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.ScoreValue)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.IsDominantPattern)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.IsDominantPattern)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Description)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Description)</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.ReportPatternScoreId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
