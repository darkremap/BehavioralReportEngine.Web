@model BehavioralReportEngine.Web.Models.Observation

@{
    ViewData["Title"] = "Edit Observation";
}

<h2>Edit Observation</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ObservationId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="SessionId" class="form-label"></label>
                <select asp-for="SessionId" class="form-select" asp-items="ViewBag.SessionId"></select>
                <span asp-validation-for="SessionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ParticipantId" class="form-label"></label>
                <select asp-for="ParticipantId" class="form-select" asp-items="ViewBag.ParticipantId"><option value="">-- None --</option></select>
                <span asp-validation-for="ParticipantId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TeamId" class="form-label"></label>
                <select asp-for="TeamId" class="form-select" asp-items="ViewBag.TeamId"><option value="">-- None --</option></select>
                <span asp-validation-for="TeamId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ObservedByUserId" class="form-label"></label>
                <select asp-for="ObservedByUserId" class="form-select" asp-items="ViewBag.ObservedByUserId"></select>
                <span asp-validation-for="ObservedByUserId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IndicatorDefinitionId" class="form-label"></label>
                <select asp-for="IndicatorDefinitionId" class="form-select" asp-items="ViewBag.IndicatorDefinitionId"><option value="">-- None --</option></select>
                <span asp-validation-for="IndicatorDefinitionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="BehavioralPatternId" class="form-label"></label>
                <select asp-for="BehavioralPatternId" class="form-select" asp-items="ViewBag.BehavioralPatternId"><option value="">-- None --</option></select>
                <span asp-validation-for="BehavioralPatternId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ObservationTimeMs" class="form-label"></label>
                <input asp-for="ObservationTimeMs" class="form-control" />
                <span asp-validation-for="ObservationTimeMs" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ObservationText" class="form-label"></label>
                <textarea asp-for="ObservationText" class="form-control" rows="3"></textarea>
                <span asp-validation-for="ObservationText" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
