<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Behavioral Report Engine</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Behavioral Report Engine</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Core (Org & Users)</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Organization" asp-action="Index">Organization</a></li>
                            <li><a class="dropdown-item" asp-controller="UserRole" asp-action="Index">User Role</a></li>
                            <li><a class="dropdown-item" asp-controller="AppUser" asp-action="Index">App User</a></li>
                            <li><a class="dropdown-item" asp-controller="AppUserRole" asp-action="Index">App User Role</a></li>
                            <li><a class="dropdown-item" asp-controller="Department" asp-action="Index">Department</a></li>
                            <li><a class="dropdown-item" asp-controller="Participant" asp-action="Index">Participant</a></li>
                            
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Game Definitions</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="GameType" asp-action="Index">Game Type</a></li>
                            <li><a class="dropdown-item" asp-controller="Game" asp-action="Index">Game</a></li>
                            <li><a class="dropdown-item" asp-controller="GameVersion" asp-action="Index">Game Version</a></li>
                            <li><a class="dropdown-item" asp-controller="ScoringScale" asp-action="Index">Scoring Scale</a></li>
                            <li><a class="dropdown-item" asp-controller="ScoringScaleLevel" asp-action="Index">Scoring Scale Level</a></li>
                            <li><a class="dropdown-item" asp-controller="IndicatorDefinition" asp-action="Index">Indicator Definition</a></li>
                            <li><a class="dropdown-item" asp-controller="BehavioralPattern" asp-action="Index">Behavioral Pattern</a></li>
                            <li><a class="dropdown-item" asp-controller="GamePattern" asp-action="Index">Game Pattern</a></li>
                            
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Sessions</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="GameSession" asp-action="Index">Game Session</a></li>
                            <li><a class="dropdown-item" asp-controller="SessionFacilitator" asp-action="Index">Session Facilitator</a></li>
                            <li><a class="dropdown-item" asp-controller="Team" asp-action="Index">Team</a></li>
                            <li><a class="dropdown-item" asp-controller="SessionParticipant" asp-action="Index">Session Participant</a></li>
                            <li><a class="dropdown-item" asp-controller="MediaAsset" asp-action="Index">Media Asset</a></li>
                            <li><a class="dropdown-item" asp-controller="Transcript" asp-action="Index">Transcript</a></li>
                            <li><a class="dropdown-item" asp-controller="TranscriptSegment" asp-action="Index">Transcript Segment</a></li>
                            <li><a class="dropdown-item" asp-controller="Observation" asp-action="Index">Observation</a></li>
                            <li><a class="dropdown-item" asp-controller="KeyMoment" asp-action="Index">Key Moment</a></li>
                            
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Report Templates</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="ReportModuleType" asp-action="Index">Report Module Type</a></li>
                            <li><a class="dropdown-item" asp-controller="ReportTemplate" asp-action="Index">Report Template</a></li>
                            <li><a class="dropdown-item" asp-controller="ReportTemplateModule" asp-action="Index">Report Template Module</a></li>
                            
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Reports</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Report" asp-action="Index">Report</a></li>
                            <li><a class="dropdown-item" asp-controller="ReportModule" asp-action="Index">Report Module</a></li>
                            <li><a class="dropdown-item" asp-controller="ReportIndicatorScore" asp-action="Index">Report Indicator Score</a></li>
                            <li><a class="dropdown-item" asp-controller="ReportPatternScore" asp-action="Index">Report Pattern Score</a></li>
                            <li><a class="dropdown-item" asp-controller="ReportKeyMoment" asp-action="Index">Report Key Moment</a></li>
                            <li><a class="dropdown-item" asp-controller="GrowthMapEntry" asp-action="Index">Growth Map Entry</a></li>
                            <li><a class="dropdown-item" asp-controller="ActionPlanItem" asp-action="Index">Action Plan Item</a></li>
                            
                        </ul>
                    </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container">
            Behavioral Report Engine &copy; @DateTime.Now.Year
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
