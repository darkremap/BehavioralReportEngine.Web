@model IEnumerable<BehavioralReportEngine.Web.Models.GameVersion>

@{
    ViewData["Title"] = "GameVersion List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Game Version</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Game Version</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.VersionNumber)</th>
            <th>@Html.DisplayNameFor(model => model.VersionLabel)</th>
            <th>@Html.DisplayNameFor(model => model.EffectiveFrom)</th>
            <th>@Html.DisplayNameFor(model => model.EffectiveTo)</th>
            <th>@Html.DisplayNameFor(model => model.IsCurrent)</th>
            <th>@Html.DisplayNameFor(model => model.ReleaseNotes)</th>
            <th>Game</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.VersionNumber</td>
                <td>@item.VersionLabel</td>
                <td>@item.EffectiveFrom.ToString("g")</td>
                <td>@item.EffectiveTo?.ToString("g")</td>
                <td>@(item.IsCurrent ? "Yes" : "No")</td>
                <td>@item.ReleaseNotes</td>
                <td>@item.Game?.NameFa</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.GameVersionId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.GameVersionId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.GameVersionId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
