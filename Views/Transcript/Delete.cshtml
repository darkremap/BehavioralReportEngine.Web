@model BehavioralReportEngine.Web.Models.Transcript

@{
    ViewData["Title"] = "Delete Transcript";
}

<h2>Delete Transcript</h2>

<div class="alert alert-warning">Are you sure you want to delete this transcript?</div>

<dl class="row">
    <dt class="col-sm-3">Game Session</dt>
    <dd class="col-sm-9">@Model.GameSession?.SessionName</dd>
<dt class="col-sm-3">Media Asset</dt>
    <dd class="col-sm-9">@Model.MediaAsset?.FileName</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.Language)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.Language)</dd>
<dt class="col-sm-3">@Html.DisplayNameFor(m => m.FullText)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(m => m.FullText)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="TranscriptId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
