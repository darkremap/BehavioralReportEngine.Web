@model IEnumerable<BehavioralReportEngine.Web.Models.Transcript>

@{
    ViewData["Title"] = "Transcript List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Transcript</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Transcript</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Language)</th>
            <th>@Html.DisplayNameFor(model => model.FullText)</th>
            <th>GameSession</th>
            <th>MediaAsset</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.Language</td>
                <td>@item.FullText</td>
                <td>@item.GameSession?.SessionName</td>
                <td>@item.MediaAsset?.FileName</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.TranscriptId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.TranscriptId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.TranscriptId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
