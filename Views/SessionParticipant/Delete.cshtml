@model BehavioralReportEngine.Web.Models.SessionParticipant

@{
    ViewData["Title"] = "Delete SessionParticipant";
}

<h2>Delete Session Participant</h2>

<div class="alert alert-warning">Are you sure you want to delete this session participant?</div>

<dl class="row">
    <dt class="col-sm-3">Game Session</dt>
    <dd class="col-sm-9">@Model.GameSession?.SessionName</dd>
<dt class="col-sm-3">Team</dt>
    <dd class="col-sm-9">@Model.Team?.TeamName</dd>
<dt class="col-sm-3">Participant</dt>
    <dd class="col-sm-9">@Model.Participant?.FirstNameFa</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="SessionParticipantId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
