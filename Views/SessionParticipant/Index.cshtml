@model IEnumerable<BehavioralReportEngine.Web.Models.SessionParticipant>

@{
    ViewData["Title"] = "SessionParticipant List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Session Participant</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Session Participant</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>GameSession</th>
            <th>Team</th>
            <th>Participant</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.GameSession?.SessionName</td>
                <td>@item.Team?.TeamName</td>
                <td>@item.Participant?.FirstNameFa</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.SessionParticipantId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.SessionParticipantId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.SessionParticipantId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
