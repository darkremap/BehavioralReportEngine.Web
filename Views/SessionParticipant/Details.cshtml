@model BehavioralReportEngine.Web.Models.SessionParticipant

@{
    ViewData["Title"] = "SessionParticipant Details";
}

<h2>Session Participant Details</h2>

<dl class="row">
    <dt class="col-sm-3">Game Session</dt>
    <dd class="col-sm-9">@Model.GameSession?.SessionName</dd>
<dt class="col-sm-3">Team</dt>
    <dd class="col-sm-9">@Model.Team?.TeamName</dd>
<dt class="col-sm-3">Participant</dt>
    <dd class="col-sm-9">@Model.Participant?.FirstNameFa</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.SessionParticipantId" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
