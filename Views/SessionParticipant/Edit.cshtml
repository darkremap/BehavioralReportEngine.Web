@model BehavioralReportEngine.Web.Models.SessionParticipant

@{
    ViewData["Title"] = "Edit SessionParticipant";
}

<h2>Edit Session Participant</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="SessionParticipantId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="SessionId" class="form-label"></label>
                <select asp-for="SessionId" class="form-select" asp-items="ViewBag.SessionId"></select>
                <span asp-validation-for="SessionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TeamId" class="form-label"></label>
                <select asp-for="TeamId" class="form-select" asp-items="ViewBag.TeamId"><option value="">-- None --</option></select>
                <span asp-validation-for="TeamId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ParticipantId" class="form-label"></label>
                <select asp-for="ParticipantId" class="form-select" asp-items="ViewBag.ParticipantId"></select>
                <span asp-validation-for="ParticipantId" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
