@model BehavioralReportEngine.Web.Models.ActionPlanItem

@{
    ViewData["Title"] = "Create ActionPlanItem";
}

<h2>Create Action Plan Item</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="ReportId" class="form-label"></label>
                <select asp-for="ReportId" class="form-select" asp-items="ViewBag.ReportId"></select>
                <span asp-validation-for="ReportId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IndicatorDefinitionId" class="form-label"></label>
                <select asp-for="IndicatorDefinitionId" class="form-select" asp-items="ViewBag.IndicatorDefinitionId"><option value="">-- None --</option></select>
                <span asp-validation-for="IndicatorDefinitionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ActionDescription" class="form-label"></label>
                <textarea asp-for="ActionDescription" class="form-control" rows="3"></textarea>
                <span asp-validation-for="ActionDescription" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TimeFrame" class="form-label"></label>
                <input asp-for="TimeFrame" class="form-control" />
                <span asp-validation-for="TimeFrame" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Priority" class="form-label"></label>
                <input asp-for="Priority" class="form-control" />
                <span asp-validation-for="Priority" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DisplayOrder" class="form-label"></label>
                <input asp-for="DisplayOrder" class="form-control" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
