@model IEnumerable<BehavioralReportEngine.Web.Models.ActionPlanItem>

@{
    ViewData["Title"] = "ActionPlanItem List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Action Plan Item</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Action Plan Item</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.ActionDescription)</th>
            <th>@Html.DisplayNameFor(model => model.TimeFrame)</th>
            <th>@Html.DisplayNameFor(model => model.Priority)</th>
            <th>@Html.DisplayNameFor(model => model.DisplayOrder)</th>
            <th>Report</th>
            <th>IndicatorDefinition</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.ActionDescription</td>
                <td>@item.TimeFrame</td>
                <td>@item.Priority</td>
                <td>@item.DisplayOrder</td>
                <td>@item.Report?.ReportTitle</td>
                <td>@item.IndicatorDefinition?.TitleEn</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.ActionPlanItemId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.ActionPlanItemId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.ActionPlanItemId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
