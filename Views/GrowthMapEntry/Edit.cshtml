@model BehavioralReportEngine.Web.Models.GrowthMapEntry

@{
    ViewData["Title"] = "Edit GrowthMapEntry";
}

<h2>Edit Growth Map Entry</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="GrowthMapEntryId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="ReportId" class="form-label"></label>
                <select asp-for="ReportId" class="form-select" asp-items="ViewBag.ReportId"></select>
                <span asp-validation-for="ReportId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IndicatorDefinitionId" class="form-label"></label>
                <select asp-for="IndicatorDefinitionId" class="form-select" asp-items="ViewBag.IndicatorDefinitionId"><option value="">-- None --</option></select>
                <span asp-validation-for="IndicatorDefinitionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Area" class="form-label"></label>
                <input asp-for="Area" class="form-control" />
                <span asp-validation-for="Area" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CurrentState" class="form-label"></label>
                <textarea asp-for="CurrentState" class="form-control" rows="3"></textarea>
                <span asp-validation-for="CurrentState" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TargetState" class="form-label"></label>
                <textarea asp-for="TargetState" class="form-control" rows="3"></textarea>
                <span asp-validation-for="TargetState" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DisplayOrder" class="form-label"></label>
                <input asp-for="DisplayOrder" class="form-control" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
