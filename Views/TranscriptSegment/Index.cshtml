@model IEnumerable<BehavioralReportEngine.Web.Models.TranscriptSegment>

@{
    ViewData["Title"] = "TranscriptSegment List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Transcript Segment</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Transcript Segment</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.SpeakerLabel)</th>
            <th>@Html.DisplayNameFor(model => model.StartTimeMs)</th>
            <th>@Html.DisplayNameFor(model => model.EndTimeMs)</th>
            <th>@Html.DisplayNameFor(model => model.SegmentText)</th>
            <th>Transcript</th>
            <th>Participant</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@item.SpeakerLabel</td>
                <td>@item.StartTimeMs</td>
                <td>@item.EndTimeMs</td>
                <td>@item.SegmentText</td>
                <td>@item.Transcript?.TranscriptId</td>
                <td>@item.Participant?.FirstNameFa</td>
                <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.TranscriptSegmentId" class="btn btn-sm btn-outline-secondary">View</a>
                <a asp-action="Edit" asp-route-id="@item.TranscriptSegmentId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.TranscriptSegmentId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
